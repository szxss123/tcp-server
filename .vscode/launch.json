{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug TCP Server",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/tcp_server",
      "args": ["8080"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: build",
      "setupCommands": [
        {
          "description": "Enable GDB pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}

