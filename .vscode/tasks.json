{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: configure",
      "type": "shell",
      "command": "cmake",
      "args": ["-S", ".", "-B", "build", "-DCMAKE_BUILD_TYPE=Debug"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: build",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build", "-j"],
      "dependsOn": "CMake: configure",
      "group": {"kind": "build", "isDefault": true},
      "problemMatcher": ["$gcc"]
    }
  ]
}

